{
  "manifest_version": 3,
  "name": "ARES — Codebase Memory",
  "version": "0.1.0",
  "description": "ARES catches PRs that re-introduce decisions your team already made.",
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icons/48.png"
  },
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "https://github.com/*",
    "http://localhost:8787/*"
  ],
  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://github.com/*"],
      "js": ["src/content.ts"],
      "css": ["src/styles.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/*"],
      "matches": ["https://github.com/*"]
    }
  ]
}
